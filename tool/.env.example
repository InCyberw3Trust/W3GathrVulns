# ─────────────────────────────────────────────────────────────────────────────
# W3GathrVulns — .env.example
#
# 1. Copy this file: cp .env.example .env
# 2. Run the setup script: ./setup.sh  (generates passwords automatically)
# 3. Or fill in the values marked CHANGE_ME manually
#
# ⚠️  Never commit .env to git — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Network / TLS ─────────────────────────────────────────────────────────────
# IP or hostname of the server (embedded in the self-signed TLS certificate SAN and used for CORS)
# Use "localhost" for local testing
SERVER_IP=localhost

# Exposed ports (defaults: 80 and 443)
HTTP_PORT=80
HTTPS_PORT=443

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=w3gathrvulns
# Strong password generated by setup.sh
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=w3gathrvulns

# ── Backend FastAPI ───────────────────────────────────────────────────────────
# Secret key for signing JWT tokens — must be long and random
SECRET_KEY=CHANGE_ME

# CORS: JSON array of allowed origins
# Replace with your actual domain or IP
CORS_ORIGINS=["https://CHANGE_ME"]

# Debug mode (keep false in production)
DEBUG=false

# ── Authentication ─────────────────────────────────────────────────────────────
# Credentials for the web interface (login page)
UI_USERNAME=admin
UI_PASSWORD=CHANGE_ME

# API tokens for CI/CD integrations (curl, scripts)
# API_TOKEN_READ  : GET-only access (dashboard, exports)
# API_TOKEN_WRITE : full access (ingest, mutations)
# Leave empty to disable the corresponding token
API_TOKEN_READ=CHANGE_ME
API_TOKEN_WRITE=CHANGE_ME

# JWT session duration in hours (default: 24)
JWT_EXPIRE_HOURS=24

# ── Demo mode ──────────────────────────────────────────────────────────────────
# When true: disables token/password changes via the UI/API and resets all data
# every hour with sample findings. Use only for a public demonstration instance.
DEMO_MODE=false
